rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Patients folder - her kullanıcı sadece kendi klasörüne erişebilir
    match /patients/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Diğer herhangi bir yere erişim yasak
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
} 